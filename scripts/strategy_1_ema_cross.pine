//@version=5
indicator(title="Strategy 1 - EMA Cross VWAP RSI MACD Full", overlay=true)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
ema_fast_len  = input.int(9,  title="EMA Fast Length")
ema_slow_len  = input.int(21, title="EMA Slow Length")
rsi_len       = input.int(14, title="RSI Length")
rsi_ob        = input.int(70, title="RSI Overbought")
rsi_os        = input.int(30, title="RSI Oversold")
adx_len       = input.int(14, title="ADX Length")
adx_threshold = input.int(20, title="ADX Min Threshold (trend strength)")
bb_len        = input.int(20, title="Bollinger Band Length")
bb_mult       = input.float(2.0, title="Bollinger Band Std Dev")
vol_mult      = input.float(1.2, title="Volume Spike Multiplier")
atr_len       = input.int(14, title="ATR Length")
atr_sl_mult   = input.float(1.5, title="ATR Stop Loss Multiplier")
atr_tp_mult   = input.float(3.0, title="ATR Take Profit Multiplier")

// ═══════════════════════════════════════════════════════════════
// CORE INDICATORS
// ═══════════════════════════════════════════════════════════════
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
ema_200  = ta.ema(close, 200)
vwap_val = ta.vwap(hlc3)
rsi_val  = ta.rsi(close, rsi_len)

macd_fast  = ta.ema(close, 12)
macd_slow  = ta.ema(close, 26)
macd_line  = macd_fast - macd_slow
macd_sig   = ta.ema(macd_line, 9)
macd_hist  = macd_line - macd_sig

[diplus, diminus, adx_val] = ta.dmi(adx_len, adx_len)

bb_basis = ta.sma(close, bb_len)
bb_dev   = ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_mult * bb_dev
bb_lower = bb_basis - bb_mult * bb_dev

vol_avg   = ta.sma(volume, 20)
vol_spike = volume > vol_avg * vol_mult

atr_val = ta.atr(atr_len)

// ═══════════════════════════════════════════════════════════════
// REGIME
// ═══════════════════════════════════════════════════════════════
is_trending = adx_val > adx_threshold
is_ranging  = adx_val <= adx_threshold
bull_trend  = is_trending and close > ema_200
bear_trend  = is_trending and close < ema_200

// ═══════════════════════════════════════════════════════════════
// MARKET HOURS
// ═══════════════════════════════════════════════════════════════
in_hours = not na(time("5", "0945-1545:23456"))
eod_time = not na(time("5", "1545-1600:23456"))

// ═══════════════════════════════════════════════════════════════
// ENTRY SIGNALS
// ═══════════════════════════════════════════════════════════════
ema_bull_cross = ta.crossover(ema_fast, ema_slow)
above_vwap     = close > vwap_val
rsi_bull       = rsi_val > 50 and rsi_val < rsi_ob
macd_bull      = macd_hist > 0 and macd_hist > macd_hist[1]
trend_ok_bull  = is_trending ? diplus > diminus : rsi_val > 50 and rsi_val < 60

buy_signal = in_hours and ema_bull_cross and above_vwap and rsi_bull and macd_bull and trend_ok_bull and vol_spike

ema_bear_cross = ta.crossunder(ema_fast, ema_slow)
below_vwap     = close < vwap_val
rsi_bear       = rsi_val < 50 and rsi_val > rsi_os
macd_bear      = macd_hist < 0 and macd_hist < macd_hist[1]
trend_ok_bear  = is_trending ? diminus > diplus : rsi_val < 50 and rsi_val > 40

sell_signal = in_hours and ema_bear_cross and below_vwap and rsi_bear and macd_bear and trend_ok_bear and vol_spike

// ═══════════════════════════════════════════════════════════════
// POSITION TRACKING & SL/TP
// ═══════════════════════════════════════════════════════════════
var float entry_price = na
var int   position    = 0  // 1=long, -1=short, 0=flat

if buy_signal and position == 0
    entry_price := close
    position    := 1

if sell_signal and position == 0
    entry_price := close
    position    := -1

// Dynamic SL/TP anchored to entry
sl_price = position == 1  ? entry_price - atr_val * atr_sl_mult :
           position == -1 ? entry_price + atr_val * atr_sl_mult : na
tp_price = position == 1  ? entry_price + atr_val * atr_tp_mult :
           position == -1 ? entry_price - atr_val * atr_tp_mult : na

// Close conditions
hit_sl = position == 1  and low  <= sl_price or
         position == -1 and high >= sl_price
hit_tp = position == 1  and high >= tp_price or
         position == -1 and low  <= tp_price

close_signal = position != 0 and (hit_sl or hit_tp or eod_time)

if close_signal
    position    := 0
    entry_price := na

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════
plot(ema_fast,  title="EMA 9",   color=color.blue,   linewidth=1)
plot(ema_slow,  title="EMA 21",  color=color.orange, linewidth=2)
plot(ema_200,   title="EMA 200", color=color.gray,   linewidth=1)
plot(vwap_val,  title="VWAP",    color=color.purple, linewidth=2)
plot(bb_upper,  title="BB Upper",color=color.new(color.gray, 70), linewidth=1)
plot(bb_lower,  title="BB Lower",color=color.new(color.gray, 70), linewidth=1)
plot(sl_price,  title="SL",      color=color.red,    linewidth=1, style=plot.style_linebr)
plot(tp_price,  title="TP",      color=color.green,  linewidth=1, style=plot.style_linebr)

plotshape(buy_signal,   title="BUY",   style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",   textcolor=color.white, size=size.normal)
plotshape(sell_signal,  title="SELL",  style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL",  textcolor=color.white, size=size.normal)
plotshape(close_signal, title="CLOSE", style=shape.xcross,    location=location.abovebar, color=color.white, text="EXIT",  textcolor=color.white, size=size.small)

bgcolor(bull_trend ? color.new(color.green, 95) : na, title="Bull Trend")
bgcolor(bear_trend ? color.new(color.red,   95) : na, title="Bear Trend")
bgcolor(is_ranging ? color.new(color.yellow,97) : na, title="Ranging")

// ═══════════════════════════════════════════════════════════════
// ALERTS — single alert() call per bar, script sends correct JSON
// Create ONE TradingView alert: condition = "Any alert() function call"
// ═══════════════════════════════════════════════════════════════
if buy_signal
    alert('{"secret":"mysecret123","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close, '#.00') + ',"timeframe":"5m","strategy":"ema_cross","signal":"buy"}',   alert.freq_once_per_bar_close)
if sell_signal
    alert('{"secret":"mysecret123","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close, '#.00') + ',"timeframe":"5m","strategy":"ema_cross","signal":"sell"}',  alert.freq_once_per_bar_close)
if close_signal
    alert('{"secret":"mysecret123","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close, '#.00') + ',"timeframe":"5m","strategy":"ema_cross","signal":"close"}', alert.freq_once_per_bar_close)
