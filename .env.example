# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── TradingView webhook secret (you choose this string) ─────
WEBHOOK_SECRET=my-secret-token-123

# ── Paper trading ───────────────────────────────────────────
STARTING_BALANCE=10000

# ── Market data (optional — yfinance needs no key) ──────────
POLYGON_API_KEY=

# ── App settings ────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
